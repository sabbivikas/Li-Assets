{
  "expo": {
    "name": "Natura",
    "slug": "mobile",
    "owner": "REPLACE_WITH_EAS_ACCOUNT_SLUG",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#080C14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.replit.natura",
      "buildNumber": "1"
    },
    "android": {
      "backgroundColor": "#080C14"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Natura needs your location to find species observed near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
